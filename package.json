{
  "name": "bb-twitter",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node node_modules/react-native/local-cli/cli.js start",
    "android": "node node_modules/react-native/local-cli/cli.js run-android",
    "web": "react-scripts start",
    "build:android": "cd android && JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-8.jdk/Contents/Home ./gradlew assembleRelease && cd .. && node scripts/verify-release-bundle.js",
    "postinstall": "node scripts/postinstall.js",
    "prepare": "husky",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"App.tsx\" \"index.ts\"",
    "typecheck": "tsc --noEmit",
    "generate:emoji": "node scripts/generate-emoji-map.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "base64-js": "^1.5.1",
    "lucide-react": "^0.577.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-native": "0.53.3",
    "react-native-fs": "^2.11.17",
    "react-native-sound": "^0.11.2",
    "react-native-vector-icons": "6.6.0",
    "react-native-web": "^0.17.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "emoji-datasource": "^16.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "react-native-typescript-transformer": "^1.2.13",
    "react-scripts": "^5.0.1",
    "typescript": "^5.9.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
